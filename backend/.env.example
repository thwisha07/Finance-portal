# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://finance_user:secure_password@localhost:5432/springbok_finance
DB_HOST=localhost
DB_PORT=5432
DB_NAME=springbok_finance
DB_USER=finance_user
DB_PASSWORD=secure_password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRY=1800s
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email (SendGrid or similar)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@springbok.com

# ERP Integration
ERP_API_URL=https://erp-system.internal/api
ERP_API_KEY=your-erp-api-key

# SIEM (Splunk, DataDog, etc.)
SIEM_ENABLED=false
SPLUNK_HEC_URL=https://your-splunk-instance.com:8088/services/collector
SPLUNK_HEC_TOKEN=your-splunk-token

# Security
SESSION_SECRET=your-session-secret
ALLOWED_ORIGINS=localhost:3000,localhost:5173
